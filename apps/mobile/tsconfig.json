{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "types": [
      "react"
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ],
      "@sukut/shared": [
        "../../packages/shared/src/index.ts"
      ],
      "@sukut/shared/*": [
        "../../packages/shared/src/*"
      ]
    }
  },
  "include": [
    "src",
    "app",
    "expo-env.d.ts",
    "*.ts",
    "*.tsx",
    ".expo/types/**/*.ts"
  ]
}
