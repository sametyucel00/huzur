EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_CONTENT_ENV=development

# V1 default: aladhan. It uses method 13 for Diyanet İşleri Başkanlığı, Turkey.
EXPO_PUBLIC_PRAYER_PROVIDER=aladhan
EXPO_PUBLIC_ALADHAN_BASE_URL=https://api.aladhan.com/v1
EXPO_PUBLIC_ALADHAN_METHOD=13
EXPO_PUBLIC_ALADHAN_SCHOOL=0

# Sükût Ayrıcalık satın alma altyapısı
# Geliştirme varsayılanı mock sağlayıcıdır. Canlı mağaza satın alması için store seçilir.
# store: iOS'ta StoreKit, Android'de Google Play Billing kullanır. Web/Expo Go'da satın alma çalışmaz.
EXPO_PUBLIC_PURCHASE_PROVIDER=mock
EXPO_PUBLIC_SUKUT_PRIVILEGE_MONTHLY_PRODUCT_ID=sukut_privilege_monthly
EXPO_PUBLIC_SUKUT_PRIVILEGE_YEARLY_PRODUCT_ID=sukut_privilege_yearly
