{
  "name": "sukut",
  "version": "0.1.0",
  "private": true,
  "description": "Sükût monorepo: Expo mobile app, Next.js admin panel, shared TypeScript package.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "mobile": "npm --workspace apps/mobile run start",
    "admin": "npm --workspace apps/admin run dev",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "overrides": {
    "@types/react": "~18.3.12",
    "@types/react-dom": "~18.3.1",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "packageManager": "npm@10.0.0"
}
