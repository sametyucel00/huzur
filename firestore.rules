rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    match /duas/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /zikrs/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /dailyContents/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /moodContents/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /events/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /badges/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /categories/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /sources/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /appConfig/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /planTemplates/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /notificationTemplates/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
